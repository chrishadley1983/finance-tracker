# Supabase Configuration - Consolidated Database
# Using finance schema in Inventory Management App project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key (raw API-key calls: PDF vision parsing, CSV column
# mapping, transaction categorisation)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Shared AI-usage audit logging (lib/ai-usage-audit.ts)
# Points at the SHARED public.ai_api_usage table in a DIFFERENT Supabase
# project than this app's own DB. Both fall back to the values below if unset,
# so they only need overriding to point somewhere else.
AI_USAGE_SUPABASE_URL=https://modjoikyuhqzouxvieua.supabase.co
AI_USAGE_SUPABASE_KEY=sb_publishable_ZfSKKyHywBhDtS4RLLUi5w_3Q_5Fu6v

# Service-role key for the shared AI-usage project — READ-ONLY use, only by
# scripts/validate-ai-audit.mjs. The publishable key above is insert-only
# (RLS), so it cannot read rows back; validation needs this to query.
AI_USAGE_SERVICE_KEY=your-ai-usage-service-role-key
